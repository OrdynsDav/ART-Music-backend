# OAuth-токен Яндекс.Музыки (см. https://ym.marshal.dev — «Получение токена»)
YANDEX_MUSIC_TOKEN=

# Порт HTTP-сервера (не 3000 — его часто занимает Neutralino)
PORT=3001

# Язык ответов API Яндекса: ru, en, uk, …
YANDEX_MUSIC_LANGUAGE=ru

# CORS для фронта (Vite и т.д.), через запятую
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Разрешить любой origin (только для разработки)
# CORS_ALLOW_ALL=true
